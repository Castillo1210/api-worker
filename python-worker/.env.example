# .env.example - Copiar a .env y llenar valores
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# Local PostgreSQL
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=confirmo
DATABASE_USER=confirmo_app
DATABASE_PASSWORD=confirmo_app

# GCS
GCS_BUCKET=confirmo-vouchers-dev

# LlamaCloud / LlamaParse (COMPLETAR CON DATOS REALES)
LLAMA_PARSER_URL=https://api.llamaparser.com
LLAMA_CLOUD_API_KEY=llx-your_key_here
LLAMA_PARSER_TIMEOUT=30.0
LLAMA_PARSER_MAX_RETRIES=3

# API Bridge (Callback interno)
API_BRIDGE_URL=http://api-bridge:8080
INTERNAL_SECRET=your_internal_secret_32_chars_min

# Celery / Redis
CELERY_BROKER_URL=redis://host.docker.internal:6379/0
CELERY_RESULT_BACKEND=redis://host.docker.internal:6379/1

# Métricas
METRICS_PORT=9090

# Calidad
QUALITY_MIN_WIDTH=800
QUALITY_MIN_HEIGHT=600
QUALITY_MIN_BLUR_SCORE=100.0
QUALITY_MAX_GLARE_RATIO=0.15
QUALITY_MIN_CONTRAST=30.0
QUALITY_MIN_DOC_CONFIDENCE=0.7
QUALITY_PDF_DPI=200
